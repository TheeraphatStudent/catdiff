rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read/write access to catdiff folder for authenticated users
    match /catdiff {
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Allow read access to all files for authenticated users
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Deny all other writes by default
    }
  }
}
